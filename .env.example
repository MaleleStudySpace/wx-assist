# === AI Provider ===
# API 根地址 (不要以斜杠结尾)
# OpenAI 格式: 裸域名自动补 /v1，有路径(如 /v2 /api)原样使用
#   示例: https://api.deepseek.com
#         https://maas-api.cn-huabei-1.xf-yun.com/v2
# Anthropic 格式: 原样传给 SDK，SDK 自拼 /v1/messages
#   示例: https://api.anthropic.com
#         https://token-plan-sgp.xiaomimimo.com/anthropic
AI_PROVIDER_BASE_URL=

# API Key / Token
AI_PROVIDER_API_KEY=

# API 格式: "openai" | "anthropic" | "custom" | "auto"
# openai    — OpenAI Chat Completions 兼容 (默认, 适用于 DeepSeek/OpenAI/MiMo/中转等)
# anthropic — Anthropic Messages 兼容 (适用于 Claude 代理)
# custom    — 自定义端点, URL 原样使用不拼接路径
# auto      — 自动探测 (兼容旧配置)
AI_PROVIDER_TYPE=openai

# 模型 ID (如 DeepSeek-V4-Flash, deepseek-chat, gpt-4o, claude-sonnet-4-6)
AI_PROVIDER_MODEL=

# 附加参数 (JSON 字符串, 可选)
# 发送给 API 的 extra_body, 可覆盖默认的 temperature、max_tokens 等
# 示例: {"thinking":{"type":"disabled"}}  ← DeepSeek 专用
#       {"temperature":0.7,"max_tokens":8192}
AI_PROVIDER_EXTRA_BODY=

# === WeChat ===
# 微信数据目录 — wxid_* 文件夹的父目录。留空自动检测。
WECHAT_DATA_DIR=

# 微信账号标识 (如 wxid_xxxxxxxxxxxxxx)，自动检测。需要覆盖时设置此项。
WXID=

# 数据库文件路径 (如 D:\vxchat\xwechat_files\wxid_xxx\db_storage\session\session.db)
# 仅当自动检测失败时需要手动指定。
DB_PATH=

# 后端类型: "wcdb" (Windows) 或 "mac_hybrid" / "mac_ui" (macOS)
WECHAT_BACKEND=wcdb

# 逗号分隔的群名列表。"*" = 自动发现所有群
WECHAT_GROUPS=*

# === Onboarding ===
# 是否完成首次引导 (true/false)
ONBOARDING_DONE=
